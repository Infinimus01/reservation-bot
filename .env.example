# Copy this file to .env and fill in the values you actually use.
# Notes:
# - MASTER_* vars are needed on the master node.
# - WORKER_* vars are needed on each worker node.
# - Choose one Google Sheets input mode:
#   1. GOOGLE_SHEETS_CSV_URL                                    (public sheet, no auth)
#   2. GOOGLE_SHEETS_SPREADSHEET_ID + GOOGLE_SHEETS_API_KEY    (API key auth)
#   3. GOOGLE_SHEETS_SPREADSHEET_ID + service.json              (service-account auth)
# - Choose one email provider: burner, simplelogin, addy, or faker.
# - proxies.txt contains raw HOST:PORT:USER:PASS lines (one per line), not an env var.

# ---------------------------------------------------------------------------
# Master node
# ---------------------------------------------------------------------------
MASTER_HOST=0.0.0.0
MASTER_PORT=8000
MASTER_API_KEY=replace-with-a-strong-random-secret
# MASTER_STATE_DB=./master_state.db
MASTER_REQUIRE_AVAILABILITY_TRIGGER=true
# REPORTING_FLUSH_INTERVAL_SECONDS=15
# MASTER_URL=http://127.0.0.1:8000

# Availability checker loop (runs on master)
AVAILABILITY_CHECKER_SOURCE=master-availability-checker
AVAILABILITY_CHECKER_POLL_INTERVAL_SECONDS=60
AVAILABILITY_CHECKER_REQUEST_TIMEOUT_SECONDS=30
AVAILABILITY_CHECKER_PROXY_VALIDATION_CONCURRENCY=10
AVAILABILITY_CHECKER_OUTPUT_DIR=./availability_runs

# ---------------------------------------------------------------------------
# RabbitMQ
# ---------------------------------------------------------------------------
# Fixed local-process example:
RABBITMQ_URL=amqp://guest:guest@127.0.0.1:5672/%2F
RABBITMQ_BOOKING_QUEUE=booking_jobs
RABBITMQ_BOOKING_ROUTING_KEY=booking_jobs
RABBITMQ_BOOKING_EXCHANGE=selenium_bot.booking
RABBITMQ_BOOKING_RETRY_QUEUE=booking_jobs.retry
RABBITMQ_BOOKING_RETRY_ROUTING_KEY=booking_jobs.retry
RABBITMQ_BOOKING_RETRY_EXCHANGE=selenium_bot.booking.retry
RABBITMQ_BOOKING_RETRY_DELAY_MS=0
# Retry count after the first attempt. 3 = 1 initial + up to 3 retries.
RABBITMQ_BOOKING_MAX_RETRIES=3
RABBITMQ_RESULTS_QUEUE=job_results
RABBITMQ_RESULTS_ROUTING_KEY=job_results
RABBITMQ_RESULTS_EXCHANGE=selenium_bot.results
RABBITMQ_WORKER_PREFETCH_COUNT=1

# ---------------------------------------------------------------------------
# Google Sheets
# ---------------------------------------------------------------------------
GOOGLE_SHEETS_ENABLED=true

# Public CSV URL (no auth required — publish sheet to web first)
GOOGLE_SHEETS_CSV_URL=

# API-based ingest
GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id-here
GOOGLE_SHEETS_API_KEY=your-google-api-key-here

# Service-account ingest (preferred for private sheets)
GOOGLE_SHEETS_CREDENTIALS_FILE=./service.json
GOOGLE_SHEETS_CREDENTIALS_JSON=

GOOGLE_SHEETS_SYNC_INTERVAL_SECONDS=15
GOOGLE_SHEETS_TIMEOUT_SECONDS=15

# ---------------------------------------------------------------------------
# Worker
# ---------------------------------------------------------------------------
WORKER_ID=worker-01
WORKER_NAME=worker-01
WORKER_MAX_TASKS=1
WORKER_IDLE_SHUTDOWN_SECONDS=0
WORKER_EMAIL_PROVIDER=faker
WORKER_STATUS_POLL_INTERVAL_SECONDS=1

# Browser profile base directory (persistent sessions)
WORKER_BROWSER_PROFILE_BASE_DIR=./browser_profiles

# Proxy source — put live credentials in proxies.txt (gitignored)
# Optional: IPRoyal rotating residential gateway for per-attempt fresh IPs
# IPROYAL_PROXY=geo.iproyal.com:12321:<username>:<password>
# IPROYAL_PROXY_COUNTRY=us
# IPROYAL_PROXY_LIFETIME=1h
# IPROYAL_PROXY_WARMUP=true
# IPROYAL_PROXY_WARMUP_ATTEMPTS=2
# IPROYAL_PROXY_WARMUP_TIMEOUT_SECONDS=20

WAITING_ROOM_POLL_INTERVAL_SECONDS=15
WAITING_ROOM_MAX_WAIT_SECONDS=600

# ---------------------------------------------------------------------------
# CAPTCHA solvers
# ---------------------------------------------------------------------------
# CapSolver — used for Cloudflare Turnstile on the final payment page
CAPSOLVER_API_KEY=your-capsolver-api-key

# 2Captcha — used for DataDome slider challenges
TWO_CAPTCHA_API_KEY=your-2captcha-api-key
TWOCAPTCHA_API_KEY=your-2captcha-api-key

# ---------------------------------------------------------------------------
# Email providers
# ---------------------------------------------------------------------------
# burner  — BurnerMail API (recommended; generates realistic throwaway addresses)
# faker   — fully offline, random @gmail.com-style strings (no API needed)
# addy    — addy.io anonymous forwarding
# simplelogin — SimpleLogin alias API

BURNER_EMAIL_API_KEY=your-burnermail-api-key
SIMPLELOGIN_API_KEY=
ADDY_API_KEY=
ADDY_DOMAIN=anonaddy.me
